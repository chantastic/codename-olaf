{
  "name": "cloud-instance-worker-shell",
  "version": "0.1.0",
  "description": "A tiny Cloudflare Worker shell for a configurable cloud instance hello world.",
  "type": "module",
  "scripts": {
    "init": "tsx scripts/init.ts",
    "doctor": "tsx scripts/doctor.ts",
    "dev": "wrangler dev",
    "build": "wrangler types --check && tsc --noEmit",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "jsonc-parser": "^3.3.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
